---
import BookLayout from "@/layouts/BookLayout.astro"
---

<BookLayout
  title="Starred Chapters | Tao Te Ching"
  description="Your starred chapters from the Tao Te Ching."
  canonicalPath={Astro.url.pathname}
>
  <main class="mx-auto min-h-screen bg-white px-6 sm:px-10">
    <section class="mx-auto max-w-[60ch] pt-20 pb-20 sm:pt-24">
      <div class="mb-8 flex items-baseline justify-between gap-4">
        <a
          href={import.meta.env.BASE_URL}
          class="text-[rgba(100,100,100,0.9)] italic no-underline transition-colors hover:text-ink focus-visible:text-ink focus-visible:outline-none"
        >
          home
        </a>
        <h1 class="m-0 text-[1.35rem] font-medium italic text-ink">Starred Chapters</h1>
      </div>

      <div id="stars-list" class="grid gap-8">
        <p class="m-0 text-[0.92rem] leading-6 text-[rgba(78,78,78,0.82)]">No starred chapters yet.</p>
      </div>
    </section>
  </main>
</BookLayout>
