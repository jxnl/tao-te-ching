---
import BookLayout from "@/layouts/BookLayout.astro"
import { getChapter, getChapterSlugs } from "@/lib/book"
import { icons, renderIcon } from "@/lib/icons"

export function getStaticPaths() {
  return getChapterSlugs().map((slug) => ({
    params: { slug },
  }))
}

const slugs = getChapterSlugs()
const slug = Astro.params.slug as string
const chapter = getChapter(slug)
const canonicalIndex = slugs.indexOf(slug)
const prevSlug = slugs[(canonicalIndex - 1 + slugs.length) % slugs.length]
const nextSlug = slugs[(canonicalIndex + 1) % slugs.length]
const showTitle = !/^((Fragment|Chapter) \d+)$/.test(chapter.title)
const prevHref = `../${prevSlug}/`
const nextHref = `../${nextSlug}/`
const socialImage = `${import.meta.env.BASE_URL}og/${slug}.png`
const railLinkClass =
  "font-book text-[0.98rem] tracking-[0.01em] text-[rgba(92,92,92,0.88)] opacity-[0.32] no-underline transition duration-200 ease-out hover:text-ink hover:opacity-[0.72] focus-visible:text-ink focus-visible:opacity-[0.72] focus-visible:outline-none"
const railSearchClass =
  "w-full border-0 bg-transparent px-0 py-0 font-book text-[0.98rem] tracking-[0.01em] text-[rgba(92,92,92,0.88)] opacity-[0.32] outline-none transition duration-200 ease-out placeholder:text-[rgba(120,120,120,0.55)] hover:opacity-[0.72] focus:text-ink focus:opacity-[0.72]"
---

<BookLayout
  title={`${chapter.title} | Tao Te Ching`}
  description={chapter.previewText}
  socialImage={socialImage}
  canonicalPath={Astro.url.pathname}
>
  <main
    id="reader-shell"
    class="reader-shell mx-auto min-h-screen w-full max-w-none px-5 sm:px-8"
    data-reader-slug={slug}
  >
    <a
      id="prev-link"
      href={prevHref}
      class="fixed inset-y-0 left-0 z-0 w-8 cursor-w-resize sm:w-[14vw]"
      aria-label="Previous chapter"
    >
      <span class="sr-only">Previous chapter</span>
    </a>
    <a
      id="next-link"
      href={nextHref}
      class="fixed inset-y-0 right-0 z-0 w-8 cursor-e-resize sm:w-[14vw]"
      aria-label="Next chapter"
    >
      <span class="sr-only">Next chapter</span>
    </a>

    <div class="relative z-10 mx-auto grid max-w-[60ch] gap-y-10 pt-16 pb-20 min-[1260px]:max-w-none min-[1260px]:grid-cols-[minmax(0,1fr)_minmax(34rem,60ch)_minmax(0,1fr)] min-[1260px]:gap-x-[clamp(2rem,4vw,5rem)] min-[1260px]:pt-24">
      <div class="min-[1260px]:col-start-1 min-[1260px]:row-start-1 min-[1260px]:justify-self-end min-[1260px]:self-start min-[1260px]:sticky min-[1260px]:top-24">
        <nav
          class="flex flex-wrap items-center gap-x-5 gap-y-3 min-[1260px]:w-[10rem] min-[1260px]:flex-col min-[1260px]:items-start min-[1260px]:gap-y-3"
          aria-label="Reader navigation"
        >
          <a href={import.meta.env.BASE_URL} class={railLinkClass}>
            home
          </a>
          <a href={`${import.meta.env.BASE_URL}stars/`} class={railLinkClass}>
            stars
          </a>
          <form id="search-form" class="w-full max-w-[10rem]" autocomplete="off">
            <label class="sr-only" for="search-query">Search chapters</label>
            <div class="flex items-center gap-2">
              <input
                id="search-query"
                name="q"
                type="text"
                inputmode="search"
                enterkeyhint="search"
                spellcheck="false"
                autocapitalize="off"
                value={Astro.url.searchParams.get("q") || ""}
                placeholder="search"
                class={`${railSearchClass} min-w-0 flex-1`}
              />
              <button
                type="button"
                data-search-clear
                aria-label="Clear search"
                class="hidden h-4 w-4 shrink-0 border-0 bg-transparent p-0 text-[rgba(92,92,92,0.52)] opacity-[0.32] transition duration-200 ease-out hover:text-[rgba(62,62,62,0.82)] hover:opacity-[0.72] focus-visible:text-[rgba(62,62,62,0.82)] focus-visible:opacity-[0.72] focus-visible:outline-none"
              >
                <span
                  aria-hidden="true"
                  set:html={renderIcon(icons.close, "h-4 w-4 stroke-[1.7]")}
                />
              </button>
            </div>
          </form>
        </nav>
      </div>

      <article class="min-w-0 w-full max-w-[60ch] min-[1260px]:col-start-2 min-[1260px]:justify-self-center">
        <div>
          <div class="mb-7 flex items-center gap-2">
            <p class="m-0 font-book text-[0.98rem] font-semibold leading-none tracking-[0.01em] text-ink">
              {chapter.chapterLabel}
            </p>
            <button
              id="star-toggle"
              type="button"
              class="reader-star-button inline-flex h-5 w-5 items-center justify-center border-0 bg-transparent p-0 text-[rgba(115,115,115,0.75)] transition duration-150 ease-out hover:scale-[1.04] hover:text-[rgba(90,90,90,0.95)] focus-visible:scale-[1.04] focus-visible:text-[rgba(90,90,90,0.95)] focus-visible:outline-none"
              aria-label="Star chapter"
              aria-pressed="false"
            >
              <span
                aria-hidden="true"
                set:html={renderIcon(icons.star, "h-[0.92rem] w-[0.92rem] stroke-[1.75]")}
              />
            </button>
          </div>
          {
            showTitle && (
              <h1 class="mb-10 text-center font-book text-[1.15rem] italic leading-[1.25] tracking-[0.01em] text-ink sm:text-[1.2rem]">
                {chapter.title}
              </h1>
            )
          }
          <div
            class="book-page font-book text-[1.08rem] text-ink sm:text-[1.12rem]"
            set:html={chapter.bodyHtml}
          />
        </div>
      </article>

      <aside
        class="w-full border-t border-[rgba(128,128,128,0.14)] pt-8 min-[1260px]:col-start-3 min-[1260px]:row-start-1 min-[1260px]:w-full min-[1260px]:max-w-[18rem] min-[1260px]:justify-self-start min-[1260px]:self-start min-[1260px]:sticky min-[1260px]:top-24 min-[1260px]:border-t-0 min-[1260px]:pt-0"
        data-reader-community
      >
        <div class="mb-6 flex flex-wrap justify-between gap-x-6 gap-y-3">
          <p class="m-0 text-[0.92rem] italic text-[rgba(92,92,92,0.9)] opacity-[0.32] transition-opacity duration-200 ease-out hover:opacity-[0.72]">
            Marginalia
          </p>
          <p
            id="reader-activity-summary"
            class="m-0 flex max-w-[36rem] flex-wrap items-center gap-3 text-[0.9rem] leading-6 text-[rgba(70,70,70,0.88)]"
          >
            Community traces will appear here once D1 is connected.
          </p>
        </div>

        <div class="grid gap-6">
          <section aria-labelledby="related-fragments-heading">
            <h2
              id="related-fragments-heading"
              class="mb-3 text-[0.98rem] font-medium italic text-ink opacity-[0.32] transition-opacity duration-200 ease-out hover:opacity-[0.72]"
            >
              Related chapters
            </h2>
            <ul id="related-links-list" class="m-0 grid list-none gap-3 p-0">
              <li class="m-0 text-[0.92rem] leading-6 text-[rgba(78,78,78,0.82)]">
                No related chapters yet.
              </li>
            </ul>
          </section>

          <section aria-labelledby="reader-notes-heading">
            <h2
              id="reader-notes-heading"
              class="mb-3 text-[0.98rem] font-medium italic text-ink opacity-[0.32] transition-opacity duration-200 ease-out hover:opacity-[0.72]"
            >
              Notes
            </h2>
            <form id="comment-form" class="mb-4">
              <label class="sr-only" for="comment-body">Leave a note</label>
              <textarea
                id="comment-body"
                name="body"
                rows="4"
                maxlength="1200"
                placeholder="leave a note on this chapter"
                class="w-full resize-y border border-[rgba(140,140,140,0.18)] bg-[rgba(255,255,255,0.92)] px-4 py-3 font-inherit text-inherit text-ink opacity-[0.32] outline-none transition duration-200 ease-out hover:opacity-[0.72] focus:border-[rgba(110,110,110,0.45)] focus:opacity-[0.72]"
              />
              <div class="mt-3 flex items-center justify-between gap-4">
                <p
                  id="comment-status"
                  class="m-0 min-h-[1.2rem] text-[0.82rem] text-[rgba(100,100,100,0.9)]"
                  aria-live="polite"
                ></p>
                <button
                  type="submit"
                  class="border-0 bg-[#111111] px-4 py-2 text-[0.88rem] text-white opacity-[0.32] transition duration-200 ease-out hover:bg-black hover:opacity-[0.72] focus-visible:bg-black focus-visible:opacity-[0.72] focus-visible:outline-none"
                >
                  Post note
                </button>
              </div>
            </form>

            <ul id="comment-list" class="m-0 grid list-none gap-3 p-0">
              <li class="m-0 text-[0.92rem] leading-6 text-[rgba(78,78,78,0.82)]">No notes yet.</li>
            </ul>
          </section>
        </div>
      </aside>
    </div>

    <div
      id="highlight-tooltip"
      class="highlight-tooltip"
      role="toolbar"
      aria-label="Selected text actions"
    >
      <button
        id="save-highlight"
        type="button"
        class="highlight-tooltip-action"
        aria-label="Save highlight"
      >
        <span
          aria-hidden="true"
          set:html={renderIcon(icons.highlight)}
        />
      </button>
      <button
        id="search-selection"
        type="button"
        class="highlight-tooltip-action"
        aria-label="Search selected text"
      >
        <span
          aria-hidden="true"
          set:html={renderIcon(icons.search)}
        />
      </button>
    </div>

  </main>
</BookLayout>
